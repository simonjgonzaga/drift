# Drift — required environment variables for Vercel deployment.
# Copy this file to .env.local for `vercel dev`, and set each value in
# Vercel → Settings → Environment Variables for Production / Preview / Development.

# ─── Supabase ──────────────────────────────────────────────────────
# Get these from: Supabase dashboard → Project Settings → API.
# The anon key is meant to be public (it ships in the client bundle);
# Row Level Security on the database tables enforces per-user isolation.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-public-key

# ─── Gemini ────────────────────────────────────────────────────────
# Used by /api/congrats to generate the completion-screen affirmation.
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...your-gemini-api-key
